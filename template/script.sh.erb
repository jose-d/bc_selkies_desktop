#!/usr/bin/env bash
set -euo pipefail
<%
require "shellwords"
require "yaml"

config_path = "/etc/ood/config/apps/bc_selkies_desktop/config.yml"
defaults = {
  "image" => "/cvmfs/c9.phoebe.lan/cont/selkies-ood/rocky10-plasma-selfcontained_20260624.sif",
  "web_root" => "/opt/selkies-ood/web",
  "ui_title" => "Selkies KDE Desktop",
  "wayland_lib" => "/opt/selkies-ood/wayland/lib64",
  "lang" => "C.UTF-8",
  "lc_all" => "C.UTF-8",
  "default_keyboard_layout" => "us",
  "keyboard_variant" => "",
  "keyboard_options" => ""
}
site_config = if File.file?(config_path)
  YAML.safe_load(File.read(config_path), aliases: false) || {}
else
  {}
end
config = defaults.merge(site_config.transform_keys(&:to_s))
%>

resolution="<%= context.selkies_resolution %>"
width="${resolution%x*}"
height="${resolution#*x}"
encoder="<%= context.selkies_encoder %>"
framerate="<%= context.respond_to?(:selkies_framerate) ? context.selkies_framerate : "20" %>"
h264_crf="<%= context.respond_to?(:selkies_h264_crf) ? context.selkies_h264_crf : "30" %>"
paint_over_quality="<%= context.respond_to?(:selkies_paint_over_quality) ? context.selkies_paint_over_quality : "false" %>"
keyboard_layout="<%= context.respond_to?(:selkies_keyboard_layout) ? context.selkies_keyboard_layout : config.fetch("default_keyboard_layout") %>"

image=<%= Shellwords.escape(config.fetch("image").to_s) %>
selkies_web_root=<%= Shellwords.escape(config.fetch("web_root").to_s) %>
selkies_title=<%= Shellwords.escape(config.fetch("ui_title").to_s) %>
runtime_root="${TMPDIR:-/tmp}/selkies-${USER}-${SLURM_JOB_ID:-$$}"

export SELKIES_ADDR="0.0.0.0"
export SELKIES_PORT="${port:?OOD did not provide a port}"
export SELKIES_WEB_ROOT="${selkies_web_root}"
export SELKIES_MODE="websockets"
export SELKIES_ENABLE_DUAL_MODE="false"
export SELKIES_ENABLE_HTTPS="false"
export SELKIES_ENABLE_BASIC_AUTH="false"
export SELKIES_MASTER_TOKEN="${password:?OOD did not provide a password}"
export SELKIES_AUDIO_ENABLED="false"
export SELKIES_MICROPHONE_ENABLED="false"
export SELKIES_GAMEPAD_ENABLED="false"
export SELKIES_UI_SIDEBAR_SHOW_GAMEPADS="false"
export SELKIES_ENABLE_SHARING="false"
export SELKIES_ENABLE_COLLAB="false"
export SELKIES_ENABLE_SHARED="false"
export SELKIES_CLIPBOARD_ENABLED="true"
export SELKIES_FILE_TRANSFERS="none"
export SELKIES_ENCODER="${encoder}"
export SELKIES_USE_CPU="true"
export SELKIES_IS_MANUAL_RESOLUTION_MODE="false"
unset SELKIES_MANUAL_WIDTH
unset SELKIES_MANUAL_HEIGHT
export SELKIES_FRAMERATE="${framerate}"
export SELKIES_H264_CRF="${h264_crf}"
export SELKIES_USE_PAINT_OVER_QUALITY="${paint_over_quality}"
export SELKIES_UI_TITLE="${selkies_title}"
export SELKIES_DEBUG="true"
export PIXELFLUX_WAYLAND="true"
export SELKIES_WAYLAND_SOCKET_INDEX="0"
export XDG_RUNTIME_DIR="${runtime_root}/xdg-runtime"
export WAYLAND_DISPLAY="wayland-0"
export XDG_SESSION_TYPE="wayland"
export GDK_BACKEND="wayland"
export QT_QPA_PLATFORM="wayland"
export LANG=<%= Shellwords.escape(config.fetch("lang").to_s) %>
export LC_ALL=<%= Shellwords.escape(config.fetch("lc_all").to_s) %>
export XKB_DEFAULT_LAYOUT="${keyboard_layout}"
export XKB_DEFAULT_VARIANT=<%= Shellwords.escape(config.fetch("keyboard_variant").to_s) %>
export XKB_DEFAULT_OPTIONS=<%= Shellwords.escape(config.fetch("keyboard_options").to_s) %>
unset DISPLAY

selkies_wayland_lib=<%= Shellwords.escape(config.fetch("wayland_lib").to_s) %>
if [[ -d "${selkies_wayland_lib}" ]]; then
  export LD_LIBRARY_PATH="${selkies_wayland_lib}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
fi
export GST_DEBUG="${GST_DEBUG:-2,x264*:5,openh264*:5,va*:4,gl*:4}"
export GST_DEBUG_NO_COLOR="1"
export PATH="/usr/bin:/bin:${PATH}"

if ! command -v apptainer >/dev/null 2>&1; then
  echo "apptainer executable not found in PATH" >&2
  exit 127
fi
if [[ ! -r "${image}" ]]; then
  echo "Missing Apptainer image: ${image}" >&2
  exit 1
fi

apptainer_bind_args=(--bind /tmp)
if [[ -S /run/dbus/system_bus_socket ]]; then
  apptainer_bind_args+=(--bind /run/dbus/system_bus_socket:/run/dbus/system_bus_socket)
fi
selkies_cmd=(apptainer exec "${apptainer_bind_args[@]}" "${image}" start-selkies)

mkdir -p "${XDG_RUNTIME_DIR}"
chmod 700 "${runtime_root}" "${XDG_RUNTIME_DIR}"

pids=()
cleanup() {
  local rc=$?
  for pid in "${pids[@]:-}"; do
    kill "${pid}" 2>/dev/null || true
  done
  wait 2>/dev/null || true
  rm -rf "${runtime_root}" 2>/dev/null || true
  exit "${rc}"
}
trap cleanup EXIT INT TERM

dump_display_diagnostics() {
  echo "===== Selkies KDE diagnostics ====="
  date
  echo "resolution=${width}x${height} encoder=${encoder} framerate=${framerate} h264_crf=${h264_crf} keyboard_layout=${keyboard_layout}"
  env | sort | grep -E '^(DISPLAY|WAYLAND_DISPLAY|XDG_|GDK_BACKEND|QT_QPA_PLATFORM|PIXELFLUX|SELKIES|GST_|LD_LIBRARY_PATH|LANG|LC_ALL|XKB_DEFAULT_)=' || true
  echo "--- process tree candidates ---"
  ps -u "${USER}" -o pid,ppid,stat,etime,args | grep -E 'selkies|kwin|plasma|kded|Xwayland|terminal|dolphin|apptainer' | grep -v grep || true
  echo "--- wayland sockets ---"
  find "${XDG_RUNTIME_DIR}" -maxdepth 1 \( -type s -o -type p \) 2>/dev/null | sort || true
  if command -v weston-info >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    echo "--- weston-info ---"
    timeout 4 weston-info 2>&1 || true
  fi
  echo "===== end diagnostics ====="
}

wait_for_pixelflux_socket() {
  local socket_snapshot="$1"
  local pixelflux_wayland_display=""

  for _ in $(seq 1 100); do
    pixelflux_wayland_display="$(find "${XDG_RUNTIME_DIR}" -maxdepth 1 -type s -name 'wayland-*' -printf '%f\n' 2>/dev/null | sort | comm -13 "${socket_snapshot}" - | head -n 1 || true)"
    if [[ -n "${pixelflux_wayland_display}" ]]; then
      break
    fi
    if ! kill -0 "${selkies_pid}" 2>/dev/null; then
      wait "${selkies_pid}"
      return $?
    fi
    sleep 0.1
  done

  if [[ -z "${pixelflux_wayland_display}" ]]; then
    pixelflux_wayland_display="$(find "${XDG_RUNTIME_DIR}" -maxdepth 1 -type s -name 'wayland-*' -printf '%f\n' 2>/dev/null | sort | head -n 1 || true)"
  fi
  if [[ -z "${pixelflux_wayland_display}" || ! -S "${XDG_RUNTIME_DIR}/${pixelflux_wayland_display}" ]]; then
    echo "PixelFlux Wayland socket did not appear under ${XDG_RUNTIME_DIR}" >&2
    return 1
  fi

  printf '%s\n' "${pixelflux_wayland_display}"
}

dump_display_diagnostics
socket_snapshot="${runtime_root}/wayland-sockets-before"
find "${XDG_RUNTIME_DIR}" -maxdepth 1 -type s -name 'wayland-*' -printf '%f\n' 2>/dev/null | sort > "${socket_snapshot}" || true

echo "Starting Selkies PixelFlux server on ${SELKIES_ADDR}:${SELKIES_PORT} (${width}x${height})..."
"${selkies_cmd[@]}" &
selkies_pid="$!"
pids+=("${selkies_pid}")

echo "Configuring Selkies token authentication..."
token_payload=$(printf '{"%s":{"role":"controller","mk_control":true}}' "${password}")
token_configured=false
for _ in $(seq 1 100); do
  if curl -fsS \
      -H "Authorization: Bearer ${SELKIES_MASTER_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "${token_payload}" \
      "http://127.0.0.1:${SELKIES_PORT}/tokens" >/dev/null; then
    token_configured=true
    echo "Selkies token authentication configured."
    break
  fi
  if ! kill -0 "${selkies_pid}" 2>/dev/null; then
    wait "${selkies_pid}"
    exit $?
  fi
  sleep 0.1
done
if [[ "${token_configured}" != "true" ]]; then
  echo "Failed to configure Selkies token authentication." >&2
  exit 1
fi

echo "Waiting for PixelFlux Wayland socket in ${XDG_RUNTIME_DIR}..."
WAYLAND_DISPLAY="$(wait_for_pixelflux_socket "${socket_snapshot}")"
export WAYLAND_DISPLAY

echo "Starting Rocky 10 KDE Plasma container on PixelFlux Wayland socket ${WAYLAND_DISPLAY}..."
env \
  SELKIES_DESKTOP="kde" \
  SELKIES_NESTED_SOCKET="rocky10-kde" \
  SELKIES_NESTED_WIDTH="${width}" \
  SELKIES_NESTED_HEIGHT="${height}" \
  SELKIES_NESTED_LOG="${runtime_root}/rocky10-kde.log" \
  apptainer run "${apptainer_bind_args[@]}" "${image}" &
pids+=("$!")

sleep 2
dump_display_diagnostics
wait "${selkies_pid}"

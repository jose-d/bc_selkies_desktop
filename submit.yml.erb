---
<%
require "yaml"

config_path = "/etc/ood/config/apps/bc_selkies_desktop/config.yml"
defaults = {
  "nodelist" => ""
}
site_config = if File.file?(config_path)
  YAML.safe_load(File.read(config_path), aliases: false) || {}
else
  {}
end
config = defaults.merge(site_config.transform_keys(&:to_s))
nodelist = config.fetch("nodelist").to_s.strip
%>
batch_connect:
  template: basic
  script_wrapper: |
    export SLURM_EXPORT_ENV=ALL
    bash %s
  before_script: |
    port=$(find_port localhost 20000 65000)
    password=$(create_passwd 24)
    export port password
  after_script: |
    wait_until_port_used "localhost:${port}" 90
script:
  native:
<% if nodelist != "" %>
    - "--nodelist=<%= nodelist %>"
<% end %>
    - "--ntasks=1"
    - "--cpus-per-task=<%= context.respond_to?(:selkies_num_cores) ? context.selkies_num_cores : "2" %>"
